/* file: app.overlay */

/*
 * Add LittleFS partition for web UI files
 *
 * The ESP32-S3 board DTS defines default partitions:
 *   boot_partition @0x0 (64KB)
 *   slot0_partition @0x10000 (1472KB) - main app
 *   slot1_partition @0x180000 (1472KB) - OTA slot
 *   scratch_partition @0x2F0000 (64KB)
 *   storage_partition @0x300000 (64KB) - NVS
 *
 * We add LittleFS starting at 0x310000 (after storage).
 * This fits comfortably in the 8MB flash.
 */

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Delete all default partitions from the board dts to avoid confusion/overlap */
		/delete-node/ partition@0;
		/delete-node/ partition@10000;
		/delete-node/ partition@20000;
		/delete-node/ partition@170000;
		/delete-node/ partition@2c0000;
		/delete-node/ partition@2d0000;
		/delete-node/ partition@3b0000;
		/delete-node/ partition@3e0000;
		/delete-node/ partition@3f0000;

		/* Bootloader (64KB) */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(64)>;
		};

		/* Application slot 0 (3MB) */
		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 DT_SIZE_M(3)>;
		};

		/* LittleFS for web UI files (1MB) */
		lfs_partition: partition@310000 {
			label = "littlefs";
			reg = <0x00310000 DT_SIZE_M(1)>;
		};

		/* Storage/NVS (256KB) */
		storage_partition: partition@410000 {
			label = "storage";
			reg = <0x00410000 DT_SIZE_K(256)>;
		};
	};
};

/ {
	aliases {
		/* Aliases for C code access (must be lowercase with hyphens) */
		fpga-spi = &spi2;
		gnss-uart = &uart0;
		led0 = &led_blue;
	};

	chosen {
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
	};

	/* Virtual "LED" for board heartbeat if needed */
	leds {
		compatible = "gpio-leds";
		led_blue: led_0 {
			gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>; /* Onboard LED if available, optional */
		};
	};

	/* * Custom Node: Transceiver IO
	 * Groups all discrete control signals.
	 * Note: Prop names must be snake-case by Zephyr rules, 
	 * but we access them via clean struct names in C.
	 */
	transceiver_io: transceiver-io {
		compatible = "gpio-keys"; 
		
		/* FPGA Control */
		fpga_nreset: fpga-nreset {
			gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
			label = "FPGA Reset";
		};
		fpga_done: fpga-done {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "FPGA Done";
		};
		fpga_cs: fpga-cs {
			gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;
			label = "FPGA CS";
		};

		/* GNSS Timing and Control */
		pps_in: pps-in {
			gpios = <&gpio1 16 GPIO_ACTIVE_HIGH>; /* IO 48 (Bank 1, pin 16) */
			label = "GNSS PPS";
		};
		gnss_reset: gnss-reset {
			gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
			label = "GNSS Reset";
		};

		/* Power Control */
		pg_fpgacore: pg_fpgacore {
			gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>; /* IO 41 */
			label = "FPGA Core Power Good";
		};
		en_fpgaio: en_fpgaio {
			gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>; /* IO 42 */
			label = "FPGA IO Power Enable";
		};

		/* Low Pass Filter Switching */
		lpf_high: lpf-high {
			gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
			label = "LPF High Band";
		};
		lpf_low_master: lpf-low-master {
			gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;
			label = "LPF Low Master";
		};
		lpf_low1: lpf-low1 {
			gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>;
			label = "LPF Low 1";
		};
		lpf_low2: lpf-low2 {
			gpios = <&gpio0 7 GPIO_ACTIVE_HIGH>;
			label = "LPF Low 2";
		};
	};
};

/* Pin Control Definitions */

&pinctrl {
	/* SPI2 (FSPI) for FPGA Tuning */
	spi2_default: spi2_default {
		group1 {
			pinmux = <SPIM2_MISO_GPIO13>,
			         <SPIM2_MOSI_GPIO11>,
			         <SPIM2_SCLK_GPIO12>;
		};
	};

	/* UART0 for GNSS (Physically RXD0/TXD0) */
	uart0_default: uart0_default {
		group1 {
			pinmux = <UART0_TX_GPIO43>,
			         <UART0_RX_GPIO44>;
			bias-pull-up;
		};
	};
};

/* Peripheral Configuration */

&spi2 {
	status = "okay";
	pinctrl-0 = <&spi2_default>;
	pinctrl-names = "default";
	
	/* FPGA is the only device on this bus. CS managed manually during config. */
	fpga_dev: fpga@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <1000000>; /* 1MHz for maximum reliability during Slave SPI config */
	};
};

&uart0 {
	status = "okay";
	current-speed = <9600>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&uart1 {
	status = "disabled";
};

&usb_serial {
	status = "okay";
};
